{"branchingScenario":{"content":[{"type":{"library":"H5P.BranchingQuestion 1.0","params":{"branchingQuestion":{"alternatives":[{"nextContentId":1,"feedback":{"title":"<p>Quick Links<\/p>","image":{"path":"images\/image-6a2322babebf5.png","mime":"image\/png","copyright":{"license":"U"},"width":460,"height":484},"subtitle":"<p>Click on the \"InterLibrary Loan\" Link. You will be routed to a form. Please add as much item information as possible and use your north central email to request items. Unfortunatly, ebooks cannot be requested through this process and this service is unavaliable to alumni.<\/p>"},"text":"Quick Links InterLibrary Loan Form (best for when you have all the resource information ready to go)"},{"nextContentId":4,"feedback":{"title":"<p>Find your Item<\/p>","image":{"path":"images\/image-6a2323af80689.png","mime":"image\/png","copyright":{"license":"U"},"width":1828,"height":644},"subtitle":"<p>Find the item you want to request and click it's title to see more item information. Next Select \"Request Item through InterLibrary Loan\". You will be routed to complete a form. Enter any additional information and hit \"Submit Request\" at the bottom of the form.&nbsp;<\/p>"},"text":"Item Record Request (best for when you want to explore or don&#039;t know all the item&#039;s information)"}],"question":"<p>There are two ways to request an InterLibrary Loan. Which one do you want to explore?<\/p>"}},"subContentId":"5a1983de-d198-4bf3-9761-ff2fbc9bcc1f","metadata":{"contentType":"Branching Question","license":"U","title":"How to do ILL"}},"showContentTitle":false,"proceedButtonText":"Proceed","forceContentFinished":"useBehavioural","feedback":{"title":"","subtitle":""},"contentBehaviour":"enabled"},{"type":{"library":"H5P.BranchingQuestion 1.0","params":{"branchingQuestion":{"alternatives":[{"nextContentId":7,"feedback":{"title":"<p>Book<\/p>","subtitle":"<p>Click on the \"Book\/DVD\/CD\" option<\/p>","image":{"path":"images\/image-6a2327eaa24b2.png","mime":"image\/png","copyright":{"license":"U"},"width":485,"height":843}},"text":"Book\/DVD\/CD"},{"nextContentId":3,"feedback":{"title":"<p>Article<\/p>","image":{"path":"images\/image-6a23283aebdfb.png","mime":"image\/png","copyright":{"license":"U"},"width":501,"height":868},"subtitle":"<p>Click on the \"Article\" option<\/p>"},"text":"Article"}],"question":"<p>Are you requesting a Book\/DVD\/CD or an Article?<\/p>"}},"subContentId":"d66f5261-9d7d-4202-85b0-758b30b4e5a3","metadata":{"contentType":"Branching Question","license":"U","title":"Type of InterLibary Loan"}},"showContentTitle":false,"proceedButtonText":"Proceed","forceContentFinished":"useBehavioural","feedback":{"title":"","subtitle":""},"contentBehaviour":"useBehavioural"},{"type":{"library":"H5P.ImageHotspots 1.11","params":{"globalIconType":"icon","globalIcon":"plus","globalColor":"#00558c","hotspots":[{"position":{"x":12.880004882812502,"y":24.78517764512676},"hotspotIconType":"default","hotspotIcon":"plus","hotspotColor":"#981d99","alwaysFullscreen":false,"content":[{"params":{"text":"<p>Type in your first name<\/p>"},"library":"H5P.Text 1.1","metadata":{"contentType":"Text","license":"U","title":"Untitled Text"},"subContentId":"99afe29e-44af-41d0-800e-1a6c5892ed4c"}],"header":"Name"},{"position":{"x":52.4800048828125,"y":24.420984657082244},"hotspotIconType":"default","hotspotIcon":"plus","hotspotColor":"#981d99","alwaysFullscreen":false,"content":[{"params":{"text":"<p>Type in your last name<\/p>"},"library":"H5P.Text 1.1","metadata":{"contentType":"Text","license":"U","title":"Untitled Text"},"subContentId":"348e6033-a806-4337-9655-0a473be46777"}],"header":"Last Name"},{"position":{"x":12.4800048828125,"y":30.33915805008038},"hotspotIconType":"default","hotspotIcon":"plus","hotspotColor":"#981d99","alwaysFullscreen":false,"content":[{"params":{"text":"<p>Type in your NCU email address. This should look like \"[firstname].[lastname]@mail.northcentral.edu\". Your request will be cancelled if you do not use your NCU email.<\/p>"},"library":"H5P.Text 1.1","metadata":{"contentType":"Text","license":"U","title":"Untitled Text"},"subContentId":"d56e4ff5-9045-4a3d-b4fc-33c099236608"}],"header":"NCU Email"},{"position":{"x":52.4800048828125,"y":30.657827348773687},"hotspotIconType":"default","hotspotIcon":"plus","hotspotColor":"#981d99","alwaysFullscreen":false,"content":[{"params":{"text":"<p>Type in your NCU student ID number. This will be located on the back of your school ID or in Colleage under \"User Profile\"<\/p>"},"library":"H5P.Text 1.1","metadata":{"contentType":"Text","license":"U","title":"Untitled Text"},"subContentId":"ac6cb95e-2fdc-4be3-9f07-7c5471c8a0c2"}],"header":"NCU ID #"},{"position":{"x":12.4800048828125,"y":47.592896806802344},"hotspotIconType":"default","hotspotIcon":"plus","hotspotColor":"#981d99","alwaysFullscreen":false,"content":[{"params":{"text":"<p>Type in the title of your book<\/p>"},"library":"H5P.Text 1.1","metadata":{"contentType":"Text","license":"U","title":"Untitled Text"},"subContentId":"bd680d5a-5d7c-4bda-b3e5-6e2525e3a380"}],"header":"Book Title"},{"position":{"x":51.680004882812504,"y":48.09366433613534},"hotspotIconType":"default","hotspotIcon":"plus","hotspotColor":"#981d99","alwaysFullscreen":false,"content":[{"params":{"text":"<p>Type in the first and last name of the author of the book. Please include as much information as possible. If the item is produced by an organization, please type in the organization name. If the book is authored by multiple people, include all of their names.<\/p>"},"library":"H5P.Text 1.1","metadata":{"contentType":"Text","license":"U","title":"Untitled Text"},"subContentId":"764ea616-0d16-4cfa-bf93-2649ff8221be"}],"header":"Author"},{"position":{"x":12.880004882812502,"y":53.87526318784499},"hotspotIconType":"default","hotspotIcon":"plus","hotspotColor":"#981d99","alwaysFullscreen":false,"content":[{"params":{"text":"<p>Please include the International Standardized Book Number (ISBN) of the item. This can be an ISBN-10 or ISBN-13, and should be 10-13 digits. Usually this is in the copyright information of the item.&nbsp;<\/p>"},"library":"H5P.Text 1.1","metadata":{"contentType":"Text","license":"U","title":"Untitled Text"},"subContentId":"1a62d1db-29ab-4403-b0d8-277a00f9bd77"}],"header":"ISBN"},{"position":{"x":13.280004882812499,"y":59.747907681639624},"hotspotIconType":"default","hotspotIcon":"plus","hotspotColor":"#981d99","alwaysFullscreen":false,"content":[{"params":{"text":"<p>Please inlude the volume or issue of an item if you need a specific volume or edition of the resource<\/p>"},"library":"H5P.Text 1.1","metadata":{"contentType":"Text","license":"U","title":"Untitled Text"},"subContentId":"ecf0c630-7fcb-4d8b-8dfe-fdb2a115c98a"}],"header":"Vol\/Issue"},{"position":{"x":51.680004882812504,"y":59.793433107608266},"hotspotIconType":"default","hotspotIcon":"plus","hotspotColor":"#981d99","alwaysFullscreen":false,"content":[{"params":{"text":"<p>If you only need a few pages within the book, please include these here<\/p>"},"library":"H5P.Text 1.1","metadata":{"contentType":"Text","license":"U","title":"Untitled Text"},"subContentId":"d3195817-c2db-4600-b87c-4a4ea2fd6b0b"}],"header":"Pages"},{"position":{"x":12.4800048828125,"y":65.75712671672275},"hotspotIconType":"default","hotspotIcon":"plus","hotspotColor":"#981d99","alwaysFullscreen":false,"content":[{"params":{"text":"<p>If you have any additional information that maybe helpful please include it here. For example, if you need the item by a certain date<\/p>"},"library":"H5P.Text 1.1","metadata":{"contentType":"Text","license":"U","title":"Untitled Text"},"subContentId":"9487db86-76f3-47d3-b7f5-4f6e727edd7a"}],"header":"Comments"},{"position":{"x":11.6800048828125,"y":89.83952654640642},"hotspotIconType":"default","hotspotIcon":"plus","hotspotColor":"#981d99","alwaysFullscreen":false,"content":[{"params":{"text":"<p>Don't forget to hit \"Submit\"! If you do not, your request will not go through.<\/p>"},"library":"H5P.Text 1.1","metadata":{"contentType":"Text","license":"U","title":"Untitled Text"},"subContentId":"c4b7d8ff-6d97-4713-92d8-067711dd89b1"}],"header":"Submit"}],"untitledHotspotLabel":"Untitled Hotspot","closeButtonLabel":"Close","containsAudioVideoLabel":"Contains Audio\/Video","image":{"path":"images\/image-6a23285559711.png","mime":"image\/png","copyright":{"license":"U"},"width":485,"height":843}},"subContentId":"04be3a7e-c7ee-4e36-b946-e90383dbdda4","metadata":{"contentType":"Image Hotspots","license":"U","title":"Book Hotspots"}},"showContentTitle":false,"proceedButtonText":"Proceed","forceContentFinished":"useBehavioural","feedback":{"title":"","subtitle":""},"contentBehaviour":"useBehavioural","nextContentId":5},{"type":{"library":"H5P.ImageHotspots 1.11","params":{"globalIconType":"icon","globalIcon":"plus","globalColor":"#00558c","hotspots":[{"position":{"x":14.4800048828125,"y":24.316375587821828},"hotspotIconType":"default","hotspotIcon":"plus","hotspotColor":"#981d99","alwaysFullscreen":false,"content":[{"params":{"text":"<p>Please type in your first name here<\/p>"},"library":"H5P.Text 1.1","metadata":{"contentType":"Text","license":"U","title":"Untitled Text"},"subContentId":"d2dc18de-eab3-4a84-b715-e57d0e499738"}],"header":"First Name"},{"position":{"x":52.8800048828125,"y":24.179364432140922},"hotspotIconType":"default","hotspotIcon":"plus","hotspotColor":"#981d99","alwaysFullscreen":false,"content":[{"params":{"text":"<p>Please type in your last name here<\/p>"},"library":"H5P.Text 1.1","metadata":{"contentType":"Text","license":"U","title":"Untitled Text"},"subContentId":"73ca778f-4e94-4962-a8b1-a6c0992e802d"}],"header":"Last Name"},{"position":{"x":15.2800048828125,"y":46.60329825803149},"hotspotIconType":"default","hotspotIcon":"plus","hotspotColor":"#981d99","alwaysFullscreen":false,"content":[{"params":{"text":"<p>Please type in the journal name here. Most of the time journals will have the word \"journal\" in the name. For example, \"The Journal of Business Management\". Databases are not journal titles. The journal title will be listed in the citation of the resource.<\/p>"},"library":"H5P.Text 1.1","metadata":{"contentType":"Text","license":"U","title":"Untitled Text"},"subContentId":"7920425d-e4ca-4a34-a587-2dee55f0114b"}],"header":"Journal"},{"position":{"x":52.0800048828125,"y":46.83164786127404},"hotspotIconType":"default","hotspotIcon":"plus","hotspotColor":"#981d99","alwaysFullscreen":false,"content":[{"params":{"text":"<p>The International Standard Serial Number (ISSN) is usually eight digits separated by a hyphen: 1234-5679.<\/p>"},"library":"H5P.Text 1.1","metadata":{"contentType":"Text","license":"U","title":"Untitled Text"},"subContentId":"5bcb69c9-a29d-474d-b667-265c3c21d736"}],"header":"ISSN"},{"position":{"x":14.8800048828125,"y":52.12935795963386},"hotspotIconType":"default","hotspotIcon":"plus","hotspotColor":"#981d99","alwaysFullscreen":false,"content":[{"params":{"text":"<p>Please type in your article title here<\/p>"},"library":"H5P.Text 1.1","metadata":{"contentType":"Text","license":"U","title":"Untitled Text"},"subContentId":"4ffe6542-4360-4130-870f-653dc16a7c2d"}],"header":"Title"},{"position":{"x":52.8800048828125,"y":52.22069989153394},"hotspotIconType":"default","hotspotIcon":"plus","hotspotColor":"#981d99","alwaysFullscreen":false,"content":[{"params":{"text":"<p>Please type in the author's first and last name here. Please include as much information as possible. If the item is authored by an organization, please type in the organization name here. If the item is authored by multiple people, please include all authors.<\/p>"},"library":"H5P.Text 1.1","metadata":{"contentType":"Text","license":"U","title":"Untitled Text"},"subContentId":"4b2984a5-a2ae-4c8c-b0e1-f407e81d67b5"}],"header":"Author Name"},{"position":{"x":14.4800048828125,"y":57.42707154233209},"hotspotIconType":"default","hotspotIcon":"plus","hotspotColor":"#981d99","alwaysFullscreen":false,"content":[{"params":{"text":"<p>Please indlude the date of publication here<\/p>"},"library":"H5P.Text 1.1","metadata":{"contentType":"Text","license":"U","title":"Untitled Text"},"subContentId":"8ced728c-c7ff-4153-bbc3-a10a09bc9fb2"}],"header":"Date"},{"position":{"x":14.4800048828125,"y":63.27281929473868},"hotspotIconType":"default","hotspotIcon":"plus","hotspotColor":"#981d99","alwaysFullscreen":false,"content":[{"params":{"text":"<p>Please include the volume and issue number of the item here. Sometimes this will be listed as: v29 n10, <em>29<\/em>(10) or Volume 29, Issue 10. Please specify which is the volume and which is the number\/issue.<\/p>"},"library":"H5P.Text 1.1","metadata":{"contentType":"Text","license":"U","title":"Untitled Text"},"subContentId":"87fcac92-bdce-4271-b246-8a8a4756f2c6"}],"header":"Vol\/issue"},{"position":{"x":52.8800048828125,"y":62.998796983376856},"hotspotIconType":"default","hotspotIcon":"plus","hotspotColor":"#981d99","alwaysFullscreen":false,"content":[{"params":{"text":"<p>Please include what pages you would like<\/p>"},"library":"H5P.Text 1.1","metadata":{"contentType":"Text","license":"U","title":"Untitled Text"},"subContentId":"9422da8c-9db5-42cb-887a-84cab7a5e52a"}],"header":"Pages"},{"position":{"x":15.2800048828125,"y":69.57526973796882},"hotspotIconType":"default","hotspotIcon":"plus","hotspotColor":"#981d99","alwaysFullscreen":false,"content":[{"params":{"text":"<p>Please include any additional information that could be helpful. This may include that you need the resource by a certain date or if you have any information we did not ask for.<\/p>"},"library":"H5P.Text 1.1","metadata":{"contentType":"Text","license":"U","title":"Untitled Text"},"subContentId":"96918caf-02de-4449-850a-ef84d11835ff"}],"header":"Comments"},{"position":{"x":14.0800048828125,"y":93.23228654329544},"hotspotIconType":"default","hotspotIcon":"plus","hotspotColor":"#981d99","alwaysFullscreen":false,"content":[{"params":{"text":"<p>Don't forget to hit \"Submit\"! If you do not, your request will not go through.<\/p>"},"library":"H5P.Text 1.1","metadata":{"contentType":"Text","license":"U","title":"Untitled Text"},"subContentId":"4322bfe2-a9f2-4940-902d-1d12c6a51582"}],"header":"Submit"},{"position":{"x":14.8800048828125,"y":29.888107997543457},"hotspotIconType":"default","hotspotIcon":"plus","hotspotColor":"#981d99","alwaysFullscreen":false,"content":[{"params":{"text":"<p>Type in your NCU email address. This should look like \"[firstname].[lastname]@mail.northcentral.edu\". Your request will be cancelled if you do not use your NCU email.<\/p>"},"library":"H5P.Text 1.1","metadata":{"contentType":"Text","license":"U","title":"Untitled Text"},"subContentId":"4730f4d2-de3f-46f1-aa46-9ac62452b5a2"}],"header":"NCU Email Address"},{"position":{"x":52.0800048828125,"y":29.751100326200973},"hotspotIconType":"default","hotspotIcon":"plus","hotspotColor":"#981d99","alwaysFullscreen":false,"content":[{"params":{"text":"<p>Type in your NCU student ID number. This will be located on the back of your school ID or in Colleage under \"User Profile\"<\/p>"},"library":"H5P.Text 1.1","metadata":{"contentType":"Text","license":"U","title":"Untitled Text"},"subContentId":"66b84c4b-1004-4155-b61b-06ee8e8a163b"}],"header":"NCU ID"}],"untitledHotspotLabel":"Untitled Hotspot","closeButtonLabel":"Close","containsAudioVideoLabel":"Contains Audio\/Video","image":{"path":"images\/image-6a232baae47af.png","mime":"image\/png","copyright":{"license":"U"},"width":501,"height":868}},"subContentId":"b71f3633-9239-488f-8e02-5dd81868d398","metadata":{"contentType":"Image Hotspots","license":"U","title":"Article Hotspots"}},"showContentTitle":false,"proceedButtonText":"Proceed","forceContentFinished":"useBehavioural","feedback":{"title":"","subtitle":""},"contentBehaviour":"useBehavioural","nextContentId":6},{"type":{"library":"H5P.BranchingQuestion 1.0","params":{"branchingQuestion":{"alternatives":[{"nextContentId":8,"feedback":{"title":"","subtitle":""},"text":"Book\/DVD\/CD"},{"nextContentId":10,"feedback":{"title":"","subtitle":""},"text":"Article"}],"question":"<p>Are you requesting a Book\/DVD\/CD or an Article?<\/p>"}},"subContentId":"61c8ea5c-f6cc-470e-b778-13ad615a91fd","metadata":{"contentType":"Branching Question","license":"U","title":"Type of InterLibary Loan"}},"showContentTitle":false,"proceedButtonText":"Proceed","forceContentFinished":"useBehavioural","feedback":{"title":"","subtitle":""},"contentBehaviour":"useBehavioural"},{"type":{"library":"H5P.AdvancedText 1.1","params":{"text":"<p>Congradulations!! Your request has been submitted. You should expect to hear from us within 2 weeks of your request being submitted. You should get an email when your item arrives at the library. If you do not hear from us, please contact the library at <a href=\"http:\/\/library.northcentral.edu\" target=\"_blank\" rel=\"noopener noreferrer\">library.northcentral.edu<\/a><\/p>"},"subContentId":"c5b09ec5-40b3-4599-a878-8d1c8c829626","metadata":{"contentType":"Text","license":"U","title":"Request Submitted"}},"showContentTitle":false,"proceedButtonText":"Proceed","forceContentFinished":"useBehavioural","feedback":{"title":"","subtitle":""},"contentBehaviour":"useBehavioural","nextContentId":-1},{"type":{"library":"H5P.AdvancedText 1.1","params":{"text":"<p>Congradulations!! Your request has been submitted. You should expect to hear from us within 2 weeks of your request being submitted. You should get an email when your item is delivered. If you do not hear from us, please contact the library at <a href=\"http:\/\/library.northcentral.edu\" target=\"_blank\" rel=\"noopener noreferrer\">library.northcentral.edu<\/a><\/p>"},"subContentId":"a34e8f50-ff93-4f29-a193-c2c72570d91b","metadata":{"contentType":"Text","license":"U","title":"Request Submitted"}},"showContentTitle":false,"proceedButtonText":"Proceed","forceContentFinished":"useBehavioural","feedback":{"title":"","subtitle":""},"contentBehaviour":"useBehavioural","nextContentId":-1},{"type":{"library":"H5P.AdvancedText 1.1","params":{"text":"<p>Ebooks cannot be requested through interlibrary loan due to copyright restrictions<\/p>"},"subContentId":"8892882f-b89a-4bba-b7ac-69c7a4957ea4","metadata":{"contentType":"Text","license":"U","title":"Ebook Warning"}},"showContentTitle":false,"proceedButtonText":"Proceed","forceContentFinished":"useBehavioural","feedback":{"title":"","subtitle":""},"contentBehaviour":"useBehavioural","nextContentId":2},{"type":{"library":"H5P.AdvancedText 1.1","params":{"text":"<p>Ebooks cannot be requested through interlibrary loan due to copyright restrictions<\/p>"},"metadata":{"contentType":"Text","license":"U","title":"Ebook Warning"},"subContentId":"c1595bf7-f9e0-4fbf-a520-49670e21a42b"},"showContentTitle":false,"proceedButtonText":"Proceed","forceContentFinished":"useBehavioural","feedback":{"title":"","subtitle":""},"contentBehaviour":"useBehavioural","nextContentId":9},{"type":{"library":"H5P.ImageHotspots 1.11","params":{"globalIconType":"icon","globalIcon":"plus","globalColor":"#00558c","hotspots":[{"position":{"x":7.5824951171875,"y":10.060173126492183},"hotspotIconType":"default","hotspotIcon":"plus","hotspotColor":"#981d99","alwaysFullscreen":false,"content":[{"params":{"text":"<p>If the item title does not auto fill, please type in the title of the resource<\/p>"},"library":"H5P.Text 1.1","metadata":{"contentType":"Text","license":"U","title":"Untitled Text"},"subContentId":"7bb81bc4-d627-43f2-b240-4da2e979dbc9"}],"header":"Title"},{"position":{"x":52.3824951171875,"y":9.85086182534913},"hotspotIconType":"default","hotspotIcon":"plus","hotspotColor":"#981d99","alwaysFullscreen":false,"content":[{"params":{"text":"<p>If the author's name does not auto fill, please type in the name of the author. If the author is an organization, please type in the organization name. If the item is authored by multiple people, please list all of them.<\/p>"},"library":"H5P.Text 1.1","metadata":{"contentType":"Text","license":"U","title":"Untitled Text"},"subContentId":"50ad57bd-2131-4239-9dd9-b5bf97f292d0"}],"header":"Author"},{"position":{"x":7.5824951171875,"y":17.961798507714384},"hotspotIconType":"default","hotspotIcon":"plus","hotspotColor":"#981d99","alwaysFullscreen":false,"content":[{"params":{"text":"<p>If the item pubilsher does not auto fill, please type in the name of the publisher of the resource<\/p>"},"library":"H5P.Text 1.1","metadata":{"contentType":"Text","license":"U","title":"Untitled Text"},"subContentId":"e33f9675-e3e0-47ab-8731-2e616f62cef8"}],"header":"Publisher"},{"position":{"x":53.1824951171875,"y":18.485084745286336},"hotspotIconType":"default","hotspotIcon":"plus","hotspotColor":"#981d99","alwaysFullscreen":false,"content":[{"params":{"text":"<p>If the place of publication does not auto fill, please type in where the resource was published<\/p>"},"library":"H5P.Text 1.1","metadata":{"contentType":"Text","license":"U","title":"Untitled Text"},"subContentId":"b9a4afb0-7eff-4342-9964-3f45fa94dd86"}],"header":"Publication"},{"position":{"x":7.5824951171875,"y":24.97383089729281},"hotspotIconType":"default","hotspotIcon":"plus","hotspotColor":"#981d99","alwaysFullscreen":false,"content":[{"params":{"text":"<p>If the item date does not auto fill, please type in the date the resource was published<\/p>"},"library":"H5P.Text 1.1","metadata":{"contentType":"Text","license":"U","title":"Untitled Text"},"subContentId":"109f8502-42e3-468c-b142-fd4c1b59c451"}],"header":"Date"},{"position":{"x":53.982495117187504,"y":24.921507064364206},"hotspotIconType":"default","hotspotIcon":"plus","hotspotColor":"#981d99","alwaysFullscreen":false,"content":[{"params":{"text":"<p>If the item International Standardized Book Number does not auto fill, please type in the ISBN of the resource. This can be an ISBN-10 or ISBN-13, and should be 10-13 digits. Usually this is in the copyright information of the item.&nbsp;<\/p>"},"library":"H5P.Text 1.1","metadata":{"contentType":"Text","license":"U","title":"Untitled Text"},"subContentId":"8ba0732c-8bbe-4ef0-abfc-4506f7c0ba39"}],"header":"ISBN"},{"position":{"x":7.5824951171875,"y":31.933539453942632},"hotspotIconType":"default","hotspotIcon":"plus","hotspotColor":"#981d99","alwaysFullscreen":false,"content":[{"params":{"text":"<p>If the volume does not auto fill, please type in the volume or edition of the resource<\/p>"},"library":"H5P.Text 1.1","metadata":{"contentType":"Text","license":"U","title":"Untitled Text"},"subContentId":"1782008b-b892-49c6-bfae-c8cb8b569d93"}],"header":"Volume"},{"position":{"x":53.5824951171875,"y":31.671896335156656},"hotspotIconType":"default","hotspotIcon":"plus","hotspotColor":"#981d99","alwaysFullscreen":false,"content":[{"params":{"text":"<p>If the item issue does not auto fill, please type in the issue of the resource. Books do not usually have an issue number<\/p>"},"library":"H5P.Text 1.1","metadata":{"contentType":"Text","license":"U","title":"Untitled Text"},"subContentId":"111a8f36-a4b8-4951-8bd2-e8dc1cb276fc"}],"header":"Issue"},{"position":{"x":7.5824951171875,"y":38.73626054237801},"hotspotIconType":"default","hotspotIcon":"plus","hotspotColor":"#981d99","alwaysFullscreen":false,"content":[{"params":{"text":"<p>If you only want a few pages in the book, please type in the page numbers<\/p>"},"library":"H5P.Text 1.1","metadata":{"contentType":"Text","license":"U","title":"Untitled Text"},"subContentId":"476c37ee-6208-41aa-8213-f422f549f427"}],"header":"Page Number"},{"position":{"x":53.1824951171875,"y":38.840916192949535},"hotspotIconType":"default","hotspotIcon":"plus","hotspotColor":"#981d99","alwaysFullscreen":false,"content":[{"params":{"text":"<p>If you only want a chapter of the book, please type in the chapter title<\/p>"},"library":"H5P.Text 1.1","metadata":{"contentType":"Text","license":"U","title":"Untitled Text"},"subContentId":"705b0cd9-5753-4477-936f-bd1f140ddfc2"}],"header":"Chapter Title"},{"position":{"x":8.3824951171875,"y":46.00994403545673},"hotspotIconType":"default","hotspotIcon":"plus","hotspotColor":"#981d99","alwaysFullscreen":false,"content":[{"params":{"text":"<p>If you only want a chapter of a book and it has a separate author, please list their name(s) here.<\/p>"},"library":"H5P.Text 1.1","metadata":{"contentType":"Text","license":"U","title":"Untitled Text"},"subContentId":"e288f807-ad9d-4935-83b6-b0877a386fc3"}],"header":"Section Author"},{"position":{"x":53.982495117187504,"y":45.64363728138491},"hotspotIconType":"default","hotspotIcon":"plus","hotspotColor":"#981d99","alwaysFullscreen":false,"content":[{"params":{"text":"<p>An International Standard Serial Number (ISSN) is only relevant for journals, magazines, or newspapers. If you want a book, leave this blank<\/p>"},"library":"H5P.Text 1.1","metadata":{"contentType":"Text","license":"U","title":"Untitled Text"},"subContentId":"4cc14eba-fc8a-4886-8e49-96b9f823c602"}],"header":"ISSN"},{"position":{"x":8.3824951171875,"y":53.126632075606686},"hotspotIconType":"default","hotspotIcon":"plus","hotspotColor":"#981d99","alwaysFullscreen":false,"content":[{"params":{"text":"<p>If the OCLC # does not auto fill it can be found in the item information. It should be between 1 and 8 digits<\/p>"},"library":"H5P.Text 1.1","metadata":{"contentType":"Text","license":"U","title":"Untitled Text"},"subContentId":"6f2c3f26-8e85-42d5-a6a2-7bf64f5ab216"}],"header":"OCLC #"},{"position":{"x":8.3824951171875,"y":64.69126111983256},"hotspotIconType":"default","hotspotIcon":"plus","hotspotColor":"#981d99","alwaysFullscreen":false,"content":[{"params":{"text":"<p>If you want a book, select \"Book\/Media - Loan\". If you want a journal article, select \"Article\/Chapter - Copy\"<\/p>"},"library":"H5P.Text 1.1","metadata":{"contentType":"Text","license":"U","title":"Untitled Text"},"subContentId":"e058cf37-99df-4532-8cbe-57a0e80bf446"}],"header":"Media Type"},{"position":{"x":53.982495117187504,"y":64.69126111983256},"hotspotIconType":"defa